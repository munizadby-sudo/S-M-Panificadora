{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "server.js",
    "database/**/*.js",
    "middlewares/**/*.js",
    "routes/**/*.js",
    "services/**/*.js"
  ],
  "exclude": ["node_modules", "logs", "uploads"]
}